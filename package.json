    "blockman-go",
    "sandboxol",
    "api",
    "wrapper",
    "gaming"
  ],
  "author": "Mitsumi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wade04174-cmd/blockmango-wrapper"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "open": "^11.0.0"
  }
}
