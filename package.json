{
  "name": "blockmango-wrapper",
  "version": "1.0.0",
  "description": "Unofficial BlockmanGO API wrapper for Node.js/TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "create": "npx tsx tools/create-accounts.ts",
    "create-captcha": "npx tsx tools/create-with-captcha.ts",
    "popularity": "npx tsx tools/daily-popularity.ts"
  },
  "keywords": [
